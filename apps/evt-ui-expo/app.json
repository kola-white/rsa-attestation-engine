{
  "expo": {
    "name": "Cvera",
    "slug": "evt-ui-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos so you can upload verification evidence.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use your camera to capture verification evidence.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to use your microphone when recording video evidence."
        }
      ],
      "expo-secure-store"
    ],
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "kratosUrl": "https://auth.cvera.app"
    }
  }
}
