{
  "name": "rsa-attestation-engine",
  "version": "1.0.0",
  "description": "a human claims and attestations validation service",
  "scripts": {
    "validate:evt:schema": "ajv compile -s schemas/PH-1-EVT/employment.verification.v1.json --spec=draft7 -c ajv-formats",
    "validate:evt:vectors": "ajv validate -s schemas/PH-1-EVT/employment.verification.v1.json -d 'examples/PH-1-EVT/*.json' --spec=draft7 -c ajv-formats",
    "validate:evt:vectors:valid": "npm run validate:evt:vectors",
    "validate:evt:vectors:invalid": "sh -c '! ajv validate -s schemas/PH-1-EVT/employment.verification.v1.json -d \"examples/PH-1-EVT/invalid/*.json\" --spec=draft7 -c ajv-formats'",
    "test": "npm run test:ci",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:expo": "tsc -p apps/evt-ui-expo/tsconfig.json --noEmit",
    "sign-file": "node dist/pkg/issuer/sign-file.js",
    "verify": "node dist/pkg/verification/run-verify.js",
    "test:ci": "npm run validate:evt:schema && npm run validate:evt:vectors:valid && npm run validate:evt:vectors:invalid"
  },
  "keywords": [],
  "author": "Nicholas Whitehouse",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.930.0",
    "jose": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "ajv": "^8.17.1",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "glob": "^11.0.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
