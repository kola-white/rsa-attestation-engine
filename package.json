{
  "name": "rsa-attestation-engine",
  "version": "1.0.0",
  "description": "a human claims and attestations validation service",
  "scripts": {
    "validate:evt:schema": "ajv-cli compile -s schemas/PH-1-EVT/employment.verification.v1.json --spec=draft7 -c ajv-formats",
    "validate:evt:vectors": "ajv-cli validate -s schemas/PH-1-EVT/employment.verification.v1.json -d 'examples/PH-1-EVT/*.json' --spec=draft7 -c ajv-formats",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc -p tsconfig.json",
    "sign-file": "node dist/pkg/issuer/sign-file.js",
    "verify": "node dist/pkg/verification/run-verify.js",
    "test:ci": "npm run validate:evt:schema && npm run validate:evt:vectors"
  },
  "keywords": [],
  "author": "Nicholas Whitehouse",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.930.0",
    "jose": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "ajv": "^8.17.1",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "glob": "^11.0.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
