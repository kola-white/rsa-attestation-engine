{
  "id": "vp-1.verify-v1",
  "version": "1.0.0",
  "description": "Legacy verifier policy v1 aligned to VP-1. Medium-risk ATS/HR verification with fail-closed revocation.",
  "risk_tier": "MEDIUM",

  "applies_to": {
    "claim_types": ["employment.role"]
  },

  "scoring": {
    "min_score_accept": 0,
    "min_score_review": 0,
    "soft_ambiguity": {
      "enable": false,
      "margin_soft": 0,
      "margin_hard": 0,
      "max_candidates_considered": 5
    }
  },

  "recency": {
    "max_claim_age_days": null,
    "max_issued_age_days": null,
    "max_last_seen_age_days": null,
    "max_revocation_age_seconds": 900
  },

  "trust_constraints": {
    "min_trust_path_strength": 1,
    "allowed_key_states": ["active", "grace", "deprecated"]
  },

  "disposition": {
    "no_valid_attestations": "REJECT",
    "ambiguous_result": "REJECT"
  },

  "audit": {
    "emit_verification_receipt": true,
    "include_scores": true,
    "include_candidate_set_hash": true
  }
}
